---
import Layout from '../../layouts/Layout.astro';
import ChatApp from '../../components/ChatApp';

const user = Astro.locals.user;

// Protected route - user must exist due to middleware
if (!user) {
  return Astro.redirect('/login');
}

const supabase = Astro.locals.supabase;
const { userId } = Astro.params;

// Fetch all profiles for the sidebar
const { data: profiles } = await supabase
  .from('profiles')
  .select('id, username, avatar_url, last_seen, is_banned')
  .neq('id', user.id)
  .order('last_seen', { ascending: false });

---

<Layout title="Chat - ChatApp">
	<div class="flex flex-1 h-[calc(100vh-64px)] overflow-hidden">
		<ChatApp
			client:load
			currentUser={{ id: user.id, email: user.email || '' }}
			initialProfiles={profiles || []}
			initialActiveUserId={userId}
		/>
	</div>
</Layout>